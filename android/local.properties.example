# Copy this file to `local.properties` and fill in your values.
# local.properties is git-ignored so your secrets never get committed.

# Android SDK location (Android Studio usually sets this automatically).
sdk.dir=/Users/you/Library/Android/sdk

# Google Gemini API key — get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OAuth Web client ID from Firebase console (for Google Sign-In).
GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
