rules_version = '2';
// Firebase Storage security rules for SmartReader AI.
// Each user can only read/write files under their own uid folder, and PDFs are
// capped at 500 MB to match the app's performance target.
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/books/{bookId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 500 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }
  }
}
